// ====================== DAY DATA ======================
function getDayStr() { return document.getElementById('currentDate').value; }
function moOf(ds) { return ds.substring(0,7); }
function ddOf(ds) { return ds.substring(8,10); }
function emptyDay() {
  return { bottlesBought:0, bottlesExchanged:0, salaryPct:10,
           sales:[], purchase:[], driverExp:[], miscExp:[] };
}

function loadDayData() {
  const ds = getDayStr();
  setDayLabel(new Date(ds+'T00:00:00'));
  const rec = S.data[moOf(ds)]?.[ddOf(ds)]?.[curDriver] || emptyDay();
  document.getElementById('bottlesBought').value = rec.bottlesBought||0;
  document.getElementById('bottlesExchanged').value = rec.bottlesExchanged||0;
  document.getElementById('salaryPct').value = rec.salaryPct??10;
  renderTable('salesBody', rec.sales||[], 'sales');
  renderTable('purchaseBody', rec.purchase||[], 'purchase');
  renderExpRows('driverExpBody', rec.driverExp||[]);
  renderExpRows('miscExpBody', rec.miscExp||[]);
  recalc();
}

function saveDayData() {
  const ds = getDayStr(), mo = moOf(ds), dd = ddOf(ds);
  if (!S.data[mo]) S.data[mo] = {};
  if (!S.data[mo][dd]) S.data[mo][dd] = {};
  S.data[mo][dd][curDriver] = {
    bottlesBought: +document.getElementById('bottlesBought').value||0,
    bottlesExchanged: +document.getElementById('bottlesExchanged').value||0,
    salaryPct: +document.getElementById('salaryPct').value||0,
    sales: readTable('salesBody'),
    purchase: readTable('purchaseBody'),
    driverExp: readExpRows('driverExpBody'),
    miscExp: readExpRows('miscExpBody')
  };
  save();
  recalc();
}

function save() {
  // Save to localStorage as backup
  localStorage.setItem('waterApp4', JSON.stringify(S));
  // Debounce Firebase save to avoid too many writes while typing
  showSyncStatus('saving');
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    db.ref(ROOT).set(S)
      .then(() => showSyncStatus('ok'))
      .catch(err => { console.error('Save error:', err); showSyncStatus('error'); });
  }, 800);
}

