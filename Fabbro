  S.drivers.forEach((driverName, di) => {
    const rows = [[`${driverName} — ${moLabel}`],[],
      ['Дата','Куплено бут.','Обменяно бут.','% ЗП','Тип','Наименование','Цена (₽)','Наценка (₽)','Кол-во','Сумма (₽)']];
    Object.keys(moData).sort().forEach(dd => {
      const rec = moData[dd]?.[di]; if (!rec) return;
      const dateStr = `${yr}-${mnth}-${dd}`;
      const base = [dateStr, rec.bottlesBought||0, rec.bottlesExchanged||0, (rec.salaryPct||10)+'%'];
      (rec.sales||[]).forEach(p => rows.push([...base,'Продажа',p.name,p.price,p.markup,p.qty,Math.round((p.price+p.markup)*p.qty)]));
      (rec.purchase||[]).forEach(p => rows.push([...base,'Закупка',p.name,p.price,p.markup,p.qty,Math.round((p.price+p.markup)*p.qty)]));
      (rec.driverExp||[]).filter(e=>e.amount).forEach(e => rows.push([...base,'Расход вод.',e.name,'','','',e.amount]));
      (rec.miscExp||[]).filter(e=>e.amount).forEach(e => rows.push([...base,'Непредвид.',e.name,'','','',e.amount]));
    });
    const ws = XLSX.utils.aoa_to_sheet(rows);
    ws['!cols'] = Array(10).fill({wch:15});
    XLSX.utils.book_append_sheet(wb, ws, driverName.substring(0,30));
  });

  XLSX.writeFile(wb, `Учёт_воды_${mo}.xlsx`);
}

fillMonthSelect();
init();
</script>

