// ====================== RECALC ======================
function fmtR(n) { return Math.round(n).toLocaleString('ru') + ' ₽'; }
function fmtN(n) { return Math.round(n).toLocaleString('ru'); }

function recalc() {
  const sales = readTable('salesBody');
  let salesTotal = 0;
  sales.forEach((r,i) => {
    const s = (r.price+r.markup)*r.qty; salesTotal += s;
    const c = document.getElementById('ss'+i); if (c) c.textContent = fmtR(s);
  });
  document.getElementById('salesTotalCell').textContent = fmtR(salesTotal);

  const purchases = readTable('purchaseBody');
  let purchaseTotal = 0;
  purchases.forEach((r,i) => {
    const s = (r.price+r.markup)*r.qty; purchaseTotal += s;
    const c = document.getElementById('ps'+i); if (c) c.textContent = fmtR(s);
  });
  document.getElementById('purchaseTotalCell').textContent = fmtR(purchaseTotal);

  const drvExp = readExpRows('driverExpBody').reduce((s,r)=>s+r.amount, 0);
  const miscExp = readExpRows('miscExpBody').reduce((s,r)=>s+r.amount, 0);
  document.getElementById('driverExpTotal').textContent = fmtR(drvExp);
  document.getElementById('miscExpTotal').textContent = fmtR(miscExp);

  const pct = +document.getElementById('salaryPct').value||0;
  const salary = salesTotal * pct / 100;
  const totalExp = drvExp + miscExp;
  const profit = salesTotal - purchaseTotal - salary - totalExp;

  document.getElementById('dayStatCards').innerHTML = `
    <div class="stat-card"><div class="stat-label">Продажи</div><div class="stat-value" style="font-size:17px;">${fmtR(salesTotal)}</div></div>
    <div class="stat-card red"><div class="stat-label">Закупка</div><div class="stat-value" style="font-size:17px;">${fmtR(purchaseTotal)}</div></div>
    <div class="stat-card amber"><div class="stat-label">ЗП вод. (${pct}%)</div><div class="stat-value" style="font-size:17px;">${fmtR(salary)}</div></div>
    <div class="stat-card purple"><div class="stat-label">Расходы</div><div class="stat-value" style="font-size:17px;">${fmtR(totalExp)}</div></div>`;

  document.getElementById('dailyFinal').textContent = fmtR(profit);
  document.getElementById('dailyExpTotal').textContent = fmtR(totalExp);
  document.getElementById('dailyTotalBox').style.background = profit >= 0
    ? 'linear-gradient(135deg,#057a55,#046047)'
    : 'linear-gradient(135deg,#c81e1e,#9b1a1a)';
}

// ====================== SUMMARY ======================
function renderSummary() {
  updateMonthLabel();
  const mo = getMonth(), moData = S.data[mo]||{};
  const stats = S.drivers.map((name,di) => {
    let days=0,bought=0,exch=0,salesT=0,purchaseT=0,drvExp=0,miscExp=0,salary=0;
    Object.values(moData).forEach(dayObj => {
      const r = dayObj[di]; if (!r) return;
      const st = (r.sales||[]).reduce((s,p)=>s+(p.price+p.markup)*p.qty, 0);
      const pt = (r.purchase||[]).reduce((s,p)=>s+(p.price+p.markup)*p.qty, 0);
      if (st > 0 || (r.bottlesBought||0) > 0) days++;
      bought += r.bottlesBought||0; exch += r.bottlesExchanged||0;
      salesT += st; purchaseT += pt;
      drvExp += (r.driverExp||[]).reduce((s,e)=>s+e.amount, 0);
      miscExp += (r.miscExp||[]).reduce((s,e)=>s+e.amount, 0);
      salary += st * (r.salaryPct||10) / 100;
    });
    const profit = salesT - purchaseT - salary - drvExp - miscExp;
    return {name,days,bought,exch,salesT,purchaseT,drvExp,miscExp,salary,profit};
  });

  const tS = stats.reduce((s,d)=>s+d.salesT,0);
  const tP = stats.reduce((s,d)=>s+d.purchaseT,0);
  const tSal = stats.reduce((s,d)=>s+d.salary,0);
  const tProfit = stats.reduce((s,d)=>s+d.profit,0);

  document.getElementById('summaryStats').innerHTML = `
    <div class="stat-card"><div class="stat-label">Продажи</div><div class="stat-value">${fmtR(tS)}</div></div>
    <div class="stat-card red"><div class="stat-label">Закупка</div><div class="stat-value">${fmtR(tP)}</div></div>
    <div class="stat-card amber"><div class="stat-label">Зарплаты</div><div class="stat-value">${fmtR(tSal)}</div></div>
    <div class="stat-card green"><div class="stat-label">Чистая прибыль</div><div class="stat-value">${fmtR(tProfit)}</div></div>`;

  const tbody = document.getElementById('summaryBody');
  tbody.innerHTML = '';
  stats.forEach(d => {
    const pb = d.profit >= 0 ? `<span class="sbadge bg">${fmtR(d.profit)}</span>` : `<span class="sbadge br">${fmtR(d.profit)}</span>`;
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="font-weight:600;text-align:left;">${escQ(d.name)}</td>
      <td>${d.days}</td><td>${fmtN(d.bought)}</td><td>${fmtN(d.exch)}</td>
      <td style="font-weight:600;">${fmtR(d.salesT)}</td>
      <td>${fmtR(d.purchaseT)}</td><td>${fmtR(d.drvExp)}</td><td>${fmtR(d.miscExp)}</td>
      <td><span class="sbadge ba">${fmtR(d.salary)}</span></td><td>${pb}</td>`;
    tbody.appendChild(tr);
  });

  document.getElementById('summaryFoot').innerHTML = `<tr>
    <td style="font-weight:700;text-align:left;">ИТОГО</td><td></td>
    <td>${fmtN(stats.reduce((s,d)=>s+d.bought,0))}</td>
    <td>${fmtN(stats.reduce((s,d)=>s+d.exch,0))}</td>
    <td style="font-weight:700;">${fmtR(tS)}</td>
    <td>${fmtR(tP)}</td>
    <td>${fmtR(stats.reduce((s,d)=>s+d.drvExp,0))}</td>
    <td>${fmtR(stats.reduce((s,d)=>s+d.miscExp,0))}</td>
    <td>${fmtR(tSal)}</td>
    <td style="font-weight:700;color:${tProfit>=0?'var(--green)':'var(--red)'};">${fmtR(tProfit)}</td>
  </tr>`;
}

